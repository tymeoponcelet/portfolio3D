{
  "cssVars": {
    "--button-highlight": "#fff",
    "--button-face": "#747474",
    "--button-shadow": "grey",
    "--window-frame": "#2b2b2b",
    "--surface": "silver",
    "--surface-hover": "#e9e9e9",
    "--border-field": "inset -1px -1px var(--button-highlight),inset 1px 1px var(--button-shadow),inset -2px -2px var(--button-face),inset 2px 2px var(--window-frame)",
    "--border-raised-outer": "inset -1px -1px var(--window-frame),inset 1px 1px var(--button-highlight)",
    "--border-raised-inner": "inset -2px -2px var(--button-shadow),inset 2px 2px var(--button-face)"
  },
  "colors": {
    "desktop": "#008080",
    "surface": "#c0c0c0",
    "surfaceHover": "#e9e9e9",
    "titlebarActiveFrom": "#000080",
    "titlebarActiveTo": "#1084d0",
    "titlebarInactive": "#808080",
    "titlebarText": "#ffffff",
    "titlebarTextInactive": "#c0c0c0",
    "buttonFace": "#747474",
    "highlight": "#ffffff",
    "shadow": "#808080",
    "frame": "#2b2b2b",
    "inputActive": "#fbffc4",
    "taskbarBorder": "#86898d",
    "selectionBg": "#000080",
    "windowText": "#000000",
    "closeHover": "#c00000"
  },
  "dimensions": {
    "titlebarHeight": "18px",
    "taskbarHeight": "28px",
    "windowBorder": "2px",
    "windowPadding": "2px",
    "ctrlBtnWidth": "16px",
    "ctrlBtnHeight": "14px",
    "iconSize": "48px",
    "iconVertSpacing": "104px",
    "iconLeftMargin": "24px",
    "windowMinWidth": "180px",
    "windowMinHeight": "100px"
  },
  "typography": {
    "uiFont": "MSSansSerif, 'MS Sans Serif', Tahoma, Arial, sans-serif",
    "uiSize": "11px",
    "monoFont": "Terminal, 'Courier New', Courier, monospace",
    "bodyFont": "Millennium, 'Times New Roman', serif",
    "bodySize": "18px",
    "bodyFontBold": "MillenniumBold, 'Times New Roman', serif",
    "h1Font": "gastromond, sans-serif",
    "h1Size": "64px",
    "h2Font": "MillenniumBold, 'Times New Roman', serif",
    "h2Size": "32px",
    "h3Font": "MillenniumBold, 'Times New Roman', serif",
    "h3Size": "24px",
    "toolbarFont": "lores-15-bold-alt-oakland, sans-serif",
    "toolbarSize": "18px",
    "showcaseHeaderFont": "lores-15-bold-alt-oakland, sans-serif",
    "showcaseHeaderSize": "15px",
    "showcaseHeaderColor": "#ffffff",
    "fontFiles": {
      "MSSansSerif": "/static/media/MSSansSerif.ttf",
      "Millennium": "/static/media/Millennium.ttf",
      "MillenniumBold": "/static/media/Millennium-Bold.ttf",
      "Terminal": "/static/media/Terminal.ttf",
      "gastromond": "Adobe Typekit CDN",
      "lores15": "Adobe Typekit CDN"
    }
  },
  "effects": {
    "windowBoxShadow": "inset 1px 1px #ffffff, inset 2px 2px #747474, inset -1px -1px #2b2b2b, inset -2px -2px #808080",
    "ctrlBtnBoxShadow": "inset 1px 1px #ffffff, inset -1px -1px #2b2b2b",
    "backdropFilterNote": "NONE — Puppeteer audit confirms Heffernan uses no glassmorphism anywhere",
    "borderRaised": "inset  1px  1px #ffffff, inset  2px  2px #747474, inset -1px -1px #2b2b2b, inset -2px -2px #808080",
    "borderSunken": "inset  1px  1px #808080, inset  2px  2px #2b2b2b, inset -1px -1px #ffffff, inset -2px -2px #747474",
    "borderField": "inset -1px -1px #ffffff, inset  1px  1px #808080, inset -2px -2px #747474, inset  2px  2px #2b2b2b",
    "backdropFilter": "none",
    "desktopScanlines": "repeating-linear-gradient(to bottom, transparent 0px, transparent 1px, rgba(0,0,0,0.05) 1px, rgba(0,0,0,0.05) 2px)",
    "crtJitter": "jittery 0.3s ease-in-out infinite"
  }
}